# ============================================
# HƯỚNG DẪN CẤU HÌNH: sao chép file này thành .env
# và điền thông tin thực tế của bạn vào
# ============================================

# Cổng chạy server (mặc định 5000)
PORT=5000

# MongoDB Connection String
# Dùng MongoDB Atlas (Cloud): mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/projectcanhan
# Dùng MongoDB local: mongodb://localhost:27017/projectcanhan
MONGODB_URI=mongodb://localhost:27017/projectcanhan

# JWT Secret Key – đặt chuỗi bất kỳ, dài và ngẫu nhiên
JWT_SECRET=projectcanhan_super_secret_key_2024

# Thời hạn JWT token (7 ngày)
JWT_EXPIRES_IN=7d

# ============================================
# CẤU HÌNH GMAIL ĐỂ GỬI EMAIL QUÊN MẬT KHẨU
# ============================================
# Bước 1: Vào Google Account -> Security -> 2-Step Verification (bật lên)
# Bước 2: Vào App passwords -> Tạo App Password (chọn App: Mail, Device: Other)
# Bước 3: Dán App Password (16 ký tự) vào GMAIL_PASS bên dưới
GMAIL_USER=your_email@gmail.com
GMAIL_PASS=your_app_password_16_chars

# URL frontend (dùng cho link reset password trong email)
# Khi deploy production, thay bằng domain thật
CLIENT_URL=http://localhost:3000
